# Copia este archivo a ".env" y define UNA de las dos claves.
# (Si defines ambas, el sistema usa Groq.)

# Opcion A (recomendada): Groq directo. Tier gratis generoso.
# Obten la clave en: https://console.groq.com  ->  API Keys -> Create API Key
GROQ_API_KEY=gsk_pega_tu_clave_de_groq

# Opcion B: router de inferencia de HuggingFace.
# Obten el token en: https://huggingface.co/settings/tokens (tipo "Read")
# HF_TOKEN=hf_pega_tu_token
